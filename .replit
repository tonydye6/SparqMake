modules = ["nodejs-24", "postgresql-16", "python-3.11"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
ALLOWED_EMAIL_DOMAINS = "sparqgames.com"
ADMIN_EMAILS = "tony@sparqgames.com"

[userenv.development]
DEV_AUTH_BYPASS = "true"
SEED_DEMO_DATA = "true"

[userenv.production]
NODE_ENV = "production"

[nix]
channel = "stable-25_05"
